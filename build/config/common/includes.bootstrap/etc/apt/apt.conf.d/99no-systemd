// Block systemd packages during bootstrap
// This configuration is active during debootstrap

APT::Install-Recommends "false";
APT::Install-Suggests "false";
APT::Get::Assume-Yes "true";
APT::Get::Fix-Broken "true";
DPkg::Options:: "--force-confdef";
DPkg::Options:: "--force-confold";

// Pin systemd packages to negative priority so they're never installed
Package: systemd;
Pin: release *
Pin-Priority: -1;

Package: systemd-sysv;
Pin: release *
Pin-Priority: -1;
